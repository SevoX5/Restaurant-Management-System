        public void GunlukCiroGoster()// Günlük ciroyu göstermek için kullanılan bir yöntem. Veritabanından bugün yapılan siparişlerin toplam cirosunu hesaplar ve anasayfa_gunlukCiro adlı kontrol üzerinde gösterir.
        {
            using (SqlConnection connect = new SqlConnection(connection))
            {
                connect.Open();

                // TRY_CAST kullanarak varchar içindeki hatalı değerler NULL dönecek ve SUM toplayacak
                string selectData = "SELECT SUM(TRY_CAST(toplam AS DECIMAL(18,2))) FROM siparisler WHERE date_siparis = @date";

                using (SqlCommand cmd = new SqlCommand(selectData, connect))
                {
                    DateTime today = DateTime.Now.Date; // Bugünün tarihini alır (saat sıfırlanır)

                    // Tarih parametresini SqlDbType.Date olarak veriyoruz
                    cmd.Parameters.Add("@date", SqlDbType.Date).Value = today;

                    object result = cmd.ExecuteScalar();

                    if (result != null && result != DBNull.Value)
                    {
                        decimal ciro = Convert.ToDecimal(result);
                        anasayfa_gunlukCiro.Text = "$" + ciro.ToString("0.00");
                    }
                    else
                    {
                        // Eğer veritabanından NULL döndüyse (hiç satış yoksa) 0 göster
                        anasayfa_gunlukCiro.Text = "$0.00";
                    }
                }
            }
        }

